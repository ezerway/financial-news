---
interface Props {
	header?: Record<string, any>[];
	items: any[];
	title?: string;
	description?: string;
}

const { items, title, description, header } = Astro.props;
const itemKeys = Object.keys(items.at(0) || []).map((h) => ({
	label: h,
	key: h,
}));
const tableHeader = header || itemKeys;
---

<div class="px-4 sm:px-6 lg:px-8">
	<div class="sm:flex sm:items-center">
		<div class="sm:flex-auto">
			{
				title && (
					<h1 class="text-base font-semibold text-gray-900 dark:text-white">
						{title}
					</h1>
				)
			}
			{
				description && (
					<p class="mt-2 text-sm text-gray-700 dark:text-gray-300">
						{description}
					</p>
				)
			}
		</div>
	</div>
	<div class="mt-8 flow-root">
		<div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
			<div
				class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8"
			>
				<table
					class="relative min-w-full divide-y divide-gray-300 dark:divide-white/15"
				>
					<thead>
						<tr>
							{
								tableHeader.map((h, index) => (
									<th
										scope="col"
										class={
											!index
												? "py-3.5 pr-3 pl-4 text-left text-sm font-semibold text-gray-900 sm:pl-0 dark:text-white"
												: "px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white"
										}
									>
										{h.label}
									</th>
								))
							}
						</tr>
					</thead>
					<tbody
						class="divide-y divide-gray-200 dark:divide-white/10"
					>
						{
							items.map((item) => (
								<tr>
									{tableHeader.map((h, index) => (
										<td
											class={
												!index
													? "py-4 pr-3 pl-4 text-sm font-medium whitespace-nowrap text-gray-900 sm:pl-0 dark:text-white"
													: "px-3 py-4 text-sm whitespace-nowrap text-gray-500 dark:text-gray-400"
											}
										>
											<Fragment set:html={item[h.key]} />
										</td>
									))}
								</tr>
							))
						}
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>
